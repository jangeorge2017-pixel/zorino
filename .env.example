# Supabase — https://supabase.com/dashboard/project/_/settings/api
# Copy to .env.local and replace with your project credentials.
# Until configured, the app shows an empty catalog (products come from Phase 1 API import).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=https://zorino.org

# Optional: cron auth for /api/cron/* (recommended in production)
# CRON_SECRET=
# NOTIFICATION_FROM_EMAIL=notifications@zorino.org
# RESEND_API_KEY=

# Optional: force static mock catalog even when Supabase is configured
# SYNC_USE_MOCK=true

# Optional: cron + partner API keys for sync jobs (see lib/sync/config.ts)
# CRON_SECRET=
# AMAZON_PAAPI_ACCESS_KEY=
# AMAZON_PAAPI_SECRET_KEY=
# AMAZON_ASSOCIATE_TAG=
# ALIEXPRESS_APP_KEY=
# ALIEXPRESS_APP_SECRET=
# ALIEXPRESS_TRACKING_ID=
# CJDROPSHIPPING_API_KEY=

# ─── eBay Partner Network (EPN) — placeholders (production idle until configured) ───
# Developer keys: https://developer.ebay.com/my/keys
# ePN Campaign ID: https://partnernetwork.ebay.com/
# EBAY_APP_ID=
# EBAY_CERT_ID=
# EBAY_CAMPAIGN_ID=
# EBAY_OAUTH_TOKEN=
# EBAY_REFERENCE_ID=
# EBAY_SANDBOX=false

# WALMART_AFFILIATE_ID=
# TEMU_AFFILIATE_ID=
# SHOPIFY_ACCESS_TOKEN=
# NOON_API_KEY=
